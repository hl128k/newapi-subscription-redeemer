# Core runtime
REDEEMER_DB_PATH=./redeemer.db
REDEEMER_HOST=127.0.0.1
REDEEMER_PORT=8789
REDEEMER_TIMEOUT_SECONDS=20
REDEEMER_ADMIN_SECRET=replace-with-a-long-random-secret
REDEEMER_ADMIN_PREFIX=xx

# NewAPI connection
NEWAPI_BASE_URL=https://your-newapi.example.com
NEWAPI_ADMIN_ACCESS_TOKEN=replace-with-newapi-admin-access-token
NEWAPI_ADMIN_USER_ID=1

# Optional: bind | create
REDEEMER_BIND_MODE=bind
